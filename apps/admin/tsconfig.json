{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@admin/*": ["src/server/*"],
      "@admin-web/*": ["src/web/*"]
    }
  },
  "include": ["src", "scripts"]
}
